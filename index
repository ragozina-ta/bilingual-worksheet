    <script>
        // Правильные ответы
        const correctAnswers = {
            // Пирамида (часть 1)
            pyramid: {
                1: "cell",
                2: "tissue", 
                3: "organ",
                4: "organ system",
                5: "organism"
            },
            
            // Соответствие картинок и названий тканей (часть 2, задание 2.1)
            tissueMatching: {
                a: "4", // A - Эпителиальная ткань
                b: "3", // B - Соединительная ткань
                c: "1", // C - Мышечная ткань
                d: "2"  // D - Нервная ткань
            },
            
            // Соответствие тканей и функций (часть 2, задание 2.2)
            tissueFunctions: {
                1: "b", // Epithelial - Protection
                2: "a", // Connective - Transport & Support
                3: "d", // Muscle - Movement
                4: "c"  // Nervous - Control
            },
            
            // Задание 3 (часть 3)
            heart: {
                mainTissue: ["мышечная", "muscle", "мышечная ткань", "muscle tissue"],
                systemRu: ["кровеносная", "кровеносная система", "сердечно-сосудистая", "сердечно-сосудистая система"],
                systemEn: ["circulatory", "circulatory system", "cardiovascular", "cardiovascular system"]
            }
        };
        
        // Функция проверки ответов
        function checkWorksheet() {
            let correctCount = 0;
            let totalCount = 0;
            let resultsMessage = "";
            
            // Проверка пирамиды (часть 1)
            for (let i = 1; i <= 5; i++) {
                const input = document.getElementById(`pyramid-${i}`);
                const userAnswer = input.value.trim().toLowerCase();
                const correctAnswer = correctAnswers.pyramid[i];
                
                totalCount++;
                
                if (userAnswer === correctAnswer) {
                    input.classList.remove("incorrect");
                    input.classList.add("correct");
                    correctCount++;
                } else {
                    input.classList.remove("correct");
                    input.classList.add("incorrect");
                }
            }
            
            // Проверка соответствия картинок и названий тканей (часть 2, задание 2.1)
            const matchIds = ['a', 'b', 'c', 'd'];
            matchIds.forEach(letter => {
                const input = document.getElementById(`match-${letter}`);
                const userAnswer = input.value.trim();
                const correctAnswer = correctAnswers.tissueMatching[letter];
                
                totalCount++;
                
                if (userAnswer === correctAnswer) {
                    input.classList.remove("incorrect");
                    input.classList.add("correct");
                    correctCount++;
                } else {
                    input.classList.remove("correct");
                    input.classList.add("incorrect");
                }
            });
            
            // Проверка соответствия тканей и функций (часть 2, задание 2.2)
            for (let i = 1; i <= 4; i++) {
                const input = document.getElementById(`answer-${i}`);
                const userAnswer = input.value.trim().toLowerCase();
                const correctAnswer = correctAnswers.tissueFunctions[i];
                
                totalCount++;
                
                if (userAnswer === correctAnswer) {
                    input.classList.remove("incorrect");
                    input.classList.add("correct");
                    correctCount++;
                } else {
                    input.classList.remove("correct");
                    input.classList.add("incorrect");
                }
            }
            
            // Проверка задания 3 (часть 3)
            // 1. Главная ткань сердца
            const heartMainTissueInput = document.getElementById("heart-main-tissue");
            const heartMainTissueAnswer = heartMainTissueInput.value.trim().toLowerCase();
            let heartMainTissueCorrect = false;
            
            totalCount++;
            for (const correct of correctAnswers.heart.mainTissue) {
                if (heartMainTissueAnswer === correct) {
                    heartMainTissueCorrect = true;
                    break;
                }
            }
            
            if (heartMainTissueCorrect) {
                heartMainTissueInput.classList.remove("incorrect");
                heartMainTissueInput.classList.add("correct");
                correctCount++;
            } else {
                heartMainTissueInput.classList.remove("correct");
                heartMainTissueInput.classList.add("incorrect");
            }
            
            // 2. Система на русском
            const heartSystemRuInput = document.getElementById("heart-system-ru");
            const heartSystemRuAnswer = heartSystemRuInput.value.trim().toLowerCase();
            let heartSystemRuCorrect = false;
            
            totalCount++;
            for (const correct of correctAnswers.heart.systemRu) {
                if (heartSystemRuAnswer === correct) {
                    heartSystemRuCorrect = true;
                    break;
                }
            }
            
            if (heartSystemRuCorrect) {
                heartSystemRuInput.classList.remove("incorrect");
                heartSystemRuInput.classList.add("correct");
                correctCount++;
            } else {
                heartSystemRuInput.classList.remove("correct");
                heartSystemRuInput.classList.add("incorrect");
            }
            
            // 3. Система на английском
            const heartSystemEnInput = document.getElementById("heart-system-en");
            const heartSystemEnAnswer = heartSystemEnInput.value.trim().toLowerCase();
            let heartSystemEnCorrect = false;
            
            totalCount++;
            for (const correct of correctAnswers.heart.systemEn) {
                if (heartSystemEnAnswer === correct) {
                    heartSystemEnCorrect = true;
                    break;
                }
            }
            
            if (heartSystemEnCorrect) {
                heartSystemEnInput.classList.remove("incorrect");
                heartSystemEnInput.classList.add("correct");
                correctCount++;
            } else {
                heartSystemEnInput.classList.remove("correct");
                heartSystemEnInput.classList.add("incorrect");
            }
            
            // Расчет процента правильных ответов
            const percentage = Math.round((correctCount / totalCount) * 100);
            
            // Формирование сообщения о результатах
            const resultsDiv = document.getElementById("check-results");
            resultsDiv.style.display = "block";
            
            if (percentage >= 80) {
                resultsDiv.className = "check-results success";
                resultsDiv.innerHTML = `
                    🎉 Отлично! Вы правильно ответили на ${correctCount} из ${totalCount} вопросов (${percentage}%).<br>
                    🎉 Excellent! You answered ${correctCount} out of ${totalCount} questions correctly (${percentage}%).
                `;
            } else if (percentage >= 50) {
                resultsDiv.className = "check-results";
                resultsDiv.innerHTML = `
                    👍 Хорошо! Вы правильно ответили на ${correctCount} из ${totalCount} вопросов (${percentage}%).<br>
                    Продолжайте тренироваться!<br>
                    👍 Good! You answered ${correctCount} out of ${totalCount} questions correctly (${percentage}%).<br>
                    Keep practicing!
                `;
            } else {
                resultsDiv.className = "check-results error";
                resultsDiv.innerHTML = `
                    💪 Есть над чем поработать! Вы правильно ответили на ${correctCount} из ${totalCount} вопросов (${percentage}%).<br>
                    Попробуйте еще раз, используя справочную информацию выше.<br>
                    💪 There's room for improvement! You answered ${correctCount} out of ${totalCount} questions correctly (${percentage}%).<br>
                    Try again using the reference information above.
                `;
            }
            
            // Прокрутка к результатам
            resultsDiv.scrollIntoView({ behavior: 'smooth' });
        }
        
        // Проверка загрузки изображений
        document.addEventListener('DOMContentLoaded', function() {
            const images = document.querySelectorAll('img');
            
            images.forEach(img => {
                if(!img.complete) {
                    img.addEventListener('error', function() {
                        console.log('❌ Ошибка загрузки изображения:', this.src);
                        this.alt = 'Изображение не загрузилось. Пожалуйста, обновите страницу.';
                    });
                }
            });
            
            // Добавляем обработчики для полей ввода, чтобы убрать подсветку при изменении
            const inputs = document.querySelectorAll('input[type="text"]');
            inputs.forEach(input => {
                input.addEventListener('input', function() {
                    this.classList.remove("correct", "incorrect");
                });
            });
        });
    </script>
