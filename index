    <style>
        /* Стили для экрана */
        @media screen {
            * {
                box-sizing: border-box;
                font-family: 'Segoe UI', 'Comic Sans MS', 'Arial Rounded MT Bold', sans-serif;
            }
            
            body {
                background: linear-gradient(135deg, #e6f2ff 0%, #f0f7ff 100%);
                color: #333;
                margin: 0;
                padding: 20px;
                line-height: 1.5;
            }
            
            .worksheet-container {
                max-width: 21cm;
                margin: 0 auto;
                background: white;
                padding: 1.5cm;
                box-shadow: 0 10px 30px rgba(0, 102, 204, 0.2);
                border-radius: 15px;
                border: 3px solid #4a8cff;
                position: relative;
                overflow: hidden;
            }
            
            .worksheet-container::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 8px;
                background: linear-gradient(90deg, #ff6600, #0066cc, #66cc99, #9966ff);
                z-index: 1;
            }
        }
        
        /* Стили для печати */
        @media print {
            body {
                background: none;
                margin: 0;
                padding: 0;
                font-size: 12pt;
            }
            
            .worksheet-container {
                max-width: 100%;
                margin: 0;
                padding: 1.5cm;
                box-shadow: none;
                border: 1px solid #000;
                border-radius: 0;
            }
            
            .no-print {
                display: none !important;
            }
            
            /* Улучшенные отступы для печати */
            .part {
                page-break-inside: avoid;
                margin-bottom: 20pt;
            }
            
            .drawing-area-large, .motto-area {
                border: 2pt solid #000 !important;
                background: white !important;
            }
            
            .zone {
                border: 1pt solid #000 !important;
                background: #f0f0f0 !important;
                color: #000 !important;
            }
            
            .check-button {
                display: none !important;
            }
        }
        
        /* Общие стили */
        .worksheet-container {
            font-size: 11pt;
            line-height: 1.4;
